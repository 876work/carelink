    "@remix-run/react": "^2.10.3",
    "@remix-run/serve": "^2.10.3",
    "@supabase/supabase-js": "^2.49.8",
    "clsx": "^2.1.1",
    "isbot": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.10.3",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^5.1.4",
    "@netlify/remix-adapter": "^2.0.0"
